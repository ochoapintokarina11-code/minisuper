---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es" data-bs-theme="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Sistema de Información de Control y Gestión de Inventarios para un Mini Supermercado" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title} | MiniSuper Admin</title>
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
		
		<!-- Bootstrap 5 CSS -->
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
		<!-- Bootstrap Icons -->
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
		
		<!-- SweetAlert2 para Alertas Premium (Servido Localmente) -->
		<script src="/js/sweetalert2.all.min.js" is:inline></script>
		
		<style is:global>
			:root {
				--accent: 139, 92, 246; /* Violet */
				--accent-gradient: linear-gradient(135deg, rgb(var(--accent)), #4f46e5);
				--glass-bg: rgba(30, 31, 34, 0.7);
				--glass-border: rgba(255, 255, 255, 0.08);
			}
			
			body {
				font-family: 'Outfit', system-ui, sans-serif;
				background-color: #0f1014;
				color: #e5e7eb;
				min-height: 100vh;
				display: flex;
				flex-direction: column;
				background-image: 
					radial-gradient(circle at 15% 50%, rgba(var(--accent), 0.15), transparent 25%),
					radial-gradient(circle at 85% 30%, rgba(79, 70, 229, 0.15), transparent 25%);
				background-attachment: fixed;
			}

			.sidebar {
				width: 260px;
				background: var(--glass-bg);
				backdrop-filter: blur(16px);
				-webkit-backdrop-filter: blur(16px);
				border-right: 1px solid var(--glass-border);
				min-height: 100vh;
				position: fixed;
				top: 0;
				left: 0;
				z-index: 1000;
				transition: transform 0.3s ease;
			}
			
			.main-content {
				margin-left: 260px;
				padding: 2rem;
				flex: 1;
			}

			@media (max-width: 768px) {
				.sidebar {
					transform: translateX(-100%);
				}
				.sidebar.show {
					transform: translateX(0);
				}
				.main-content {
					margin-left: 0;
					padding: 1rem;
				}
			}

			.nav-link {
				color: #a1a1aa;
				border-radius: 8px;
				margin-bottom: 0.5rem;
				transition: all 0.2s ease;
				padding: 0.8rem 1.2rem;
				display: flex;
				align-items: center;
				gap: 12px;
				font-weight: 500;
				text-decoration: none;
			}

			.nav-link:hover, .nav-link.active {
				background: rgba(255, 255, 255, 0.05);
				color: #fff;
			}

			.nav-link.active {
				background: var(--accent-gradient);
				box-shadow: 0 4px 15px rgba(var(--accent), 0.3);
			}

			/* Glassmorphism Cards */
			.glass-card {
				background: var(--glass-bg);
				backdrop-filter: blur(12px);
				-webkit-backdrop-filter: blur(12px);
				border: 1px solid var(--glass-border);
				border-radius: 16px;
				box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
				padding: 1.5rem;
				transition: transform 0.3s ease, box-shadow 0.3s ease;
			}
			
			.glass-card:hover {
				transform: translateY(-2px);
				box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
			}

			/* Custom Inputs */
			.form-control, .form-select {
				background-color: rgba(0, 0, 0, 0.2);
				border: 1px solid var(--glass-border);
				color: #fff;
				border-radius: 8px;
				padding: 0.75rem 1rem;
			}
			
			.form-control:focus, .form-select:focus {
				background-color: rgba(0, 0, 0, 0.4);
				border-color: rgb(var(--accent));
				color: #fff;
				box-shadow: 0 0 0 0.25rem rgba(var(--accent), 0.25);
			}

			/* Custom Table */
			.table {
				--bs-table-bg: transparent;
				--bs-table-color: #e5e7eb;
				--bs-table-border-color: var(--glass-border);
			}
			
			.table-hover tbody tr:hover {
				background-color: rgba(255, 255, 255, 0.05);
				transition: background-color 0.2s ease;
			}
			
			th {
				text-transform: uppercase;
				font-size: 0.85rem;
				letter-spacing: 1px;
				color: #a1a1aa !important;
				font-weight: 600;
				border-bottom: 2px solid var(--glass-border) !important;
			}

			/* Badges & Alerts */
			.badge-glow-warning {
				background: rgba(245, 158, 11, 0.2);
				color: #fbbf24;
				border: 1px solid rgba(245, 158, 11, 0.3);
				box-shadow: 0 0 10px rgba(245, 158, 11, 0.2);
			}
			
			.badge-glow-danger {
				background: rgba(239, 68, 68, 0.2);
				color: #f87171;
				border: 1px solid rgba(239, 68, 68, 0.3);
				box-shadow: 0 0 10px rgba(239, 68, 68, 0.2);
			}
			
			.row-alert-stock {
				background-color: rgba(239, 68, 68, 0.08) !important;
				border-left: 3px solid #ef4444;
			}
			
			.btn-primary-gradient {
				background: var(--accent-gradient);
				border: none;
				border-radius: 8px;
				padding: 0.6rem 1.5rem;
				font-weight: 500;
				box-shadow: 0 4px 15px rgba(var(--accent), 0.3);
				transition: all 0.3s ease;
				color: white;
				text-decoration: none;
			}
			
			.btn-primary-gradient:hover {
				transform: translateY(-2px);
				box-shadow: 0 6px 20px rgba(var(--accent), 0.4);
				color: white;
			}

			.sidebar-brand {
				font-size: 1.5rem;
				font-weight: 700;
				background: var(--accent-gradient);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				margin-bottom: 2rem;
				display: block;
				text-decoration: none;
			}
			
			/* Custom Scrollbar */
			::-webkit-scrollbar {
				width: 8px;
			}
			::-webkit-scrollbar-track {
				background: transparent;
			}
			::-webkit-scrollbar-thumb {
				background: rgba(255, 255, 255, 0.1);
				border-radius: 4px;
			}
			::-webkit-scrollbar-thumb:hover {
				background: rgba(255, 255, 255, 0.2);
			}

			/* Chat General */
			.chat-widget {
				position: fixed;
				bottom: 2rem;
				right: 2rem;
				width: 350px;
				background: var(--glass-bg);
				backdrop-filter: blur(16px);
				border: 1px solid var(--glass-border);
				border-radius: 16px;
				box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
				display: flex;
				flex-direction: column;
				z-index: 1050;
				transform: translateY(120%);
				transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
				opacity: 0;
			}
			.chat-widget.open {
				transform: translateY(0);
				opacity: 1;
			}
			.chat-header {
				padding: 1rem;
				border-bottom: 1px solid var(--glass-border);
				background: rgba(255, 255, 255, 0.05);
				border-radius: 16px 16px 0 0;
				display: flex;
				justify-content: space-between;
				align-items: center;
			}
			.chat-messages {
				height: 350px;
				overflow-y: auto;
				padding: 1rem;
				display: flex;
				flex-direction: column;
				gap: 0.8rem;
			}
			.chat-input-area {
				padding: 1rem;
				border-top: 1px solid var(--glass-border);
				background: rgba(255, 255, 255, 0.02);
				border-radius: 0 0 16px 16px;
			}
			.message-bubble {
				background: rgba(255, 255, 255, 0.08);
				padding: 0.6rem 1rem;
				border-radius: 12px;
				max-width: 85%;
				align-self: flex-start;
				font-size: 0.9rem;
			}
			.message-bubble.mine {
				background: var(--accent-gradient);
				align-self: flex-end;
			}
			.message-user {
				font-size: 0.7rem;
				color: #a1a1aa;
				margin-bottom: 0.2rem;
			}
			.message-bubble.mine .message-user {
				color: #e5e7eb;
				text-align: right;
			}
		</style>
	</head>
	<body>
		<!-- Sidebar -->
		<nav class="sidebar p-4 d-flex flex-column">
			<a href="/" class="sidebar-brand">
				<i class="bi bi-shop me-2"></i>MiniSuper
			</a>
			
			<div class="nav flex-column flex-grow-1">
				<a class="nav-link {Astro.url.pathname === '/' ? 'active' : ''}" href="/">
					<i class="bi bi-box-seam"></i> Inventario
				</a>

				{/* Ocultar a Vendedor */}
				{Astro.locals.user?.rol !== 'vendedor' && (
					<a class="nav-link {Astro.url.pathname.startsWith('/productos') && Astro.url.pathname !== '/' ? 'active' : ''}" href="/productos/nuevo">
						<i class="bi bi-plus-circle"></i> Nuevo Producto
					</a>
					<a class="nav-link {Astro.url.pathname.startsWith('/categorias') ? 'active' : ''}" href="/categorias">
						<i class="bi bi-tags"></i> Categorías
					</a>
					<a class="nav-link {Astro.url.pathname.startsWith('/proveedores') ? 'active' : ''}" href="/proveedores">
						<i class="bi bi-truck"></i> Proveedores
					</a>
				)}

				{/* Ocultar a Almacenero */}
				{Astro.locals.user?.rol !== 'almacenero' && (
					<a class="nav-link {Astro.url.pathname.startsWith('/ventas') ? 'active' : ''}" href="/ventas/nueva">
						<i class="bi bi-cart3"></i> Caja Registradora
					</a>
				)}

				{/* Solo para Admin */}
				{Astro.locals.user?.rol === 'admin' && (
					<a class="nav-link {Astro.url.pathname.startsWith('/usuarios') ? 'active' : ''}" href="/usuarios" style="margin-top: 1rem; border-top: 1px solid var(--glass-border); border-radius: 0; padding-top: 1.5rem;">
						<i class="bi bi-people"></i> Personal
					</a>
				)}
			</div>
			
			<div class="mt-auto">
				<div class="d-flex align-items-center justify-content-between glass-card p-3 mb-2" style="border-radius: 12px; padding: 1rem !important;">
					<div class="d-flex align-items-center gap-3 overflow-hidden">
						<div class="rounded-circle bg-primary d-flex align-items-center justify-content-center flex-shrink-0" style="width: 40px; height: 40px;">
							<i class="bi bi-person text-white"></i>
						</div>
						<div class="overflow-hidden">
							<h6 class="mb-0 fs-6 text-white text-truncate">{Astro.locals.user?.nombre_real || 'Usuario'}</h6>
							<small class="text-muted text-uppercase" style="font-size: 0.7rem;">{Astro.locals.user?.rol || 'Rol Desconocido'}</small>
						</div>
					</div>
					<!-- Botón Chat Discreto -->
					<a href="#" id="btnToggleChat" class="text-muted text-decoration-none" title="Chat General" style="opacity: 0.5; transition: opacity 0.3s;" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=0.5">
						<i class="bi bi-chat-dots fs-5"></i>
					</a>
				</div>
				<button id="btnLogout" class="btn btn-outline-danger w-100 border-0 text-start ps-3"><i class="bi bi-box-arrow-left me-2"></i>Cerrar Sesión</button>
			</div>
		</nav>

		<!-- Main Content -->
		<main class="main-content">
			<!-- Mobile Toggle -->
			<button class="btn btn-outline-light d-md-none mb-4" id="sidebarToggle">
				<i class="bi bi-list fs-4"></i>
			</button>
			
			<slot />
		</main>

		<!-- Chat General Widget -->
		<div class="chat-widget" id="chatWidget">
			<div class="chat-header">
				<h6 class="mb-0"><i class="bi bi-chat-dots me-2"></i>Chat Global</h6>
				<button class="btn btn-sm btn-outline-light border-0" id="btnCloseChat"><i class="bi bi-x-lg"></i></button>
			</div>
			<div class="chat-messages" id="chatMessages">
				<!-- Mensajes inyectados por JS -->
				<div class="text-center text-muted mt-5"><span class="spinner-border spinner-border-sm"></span> Cargando...</div>
			</div>
			<div class="chat-input-area">
				<div class="input-group">
					<input type="text" id="chatInput" class="form-control" placeholder="Escribe un mensaje..." autocomplete="off">
					<button class="btn btn-primary-gradient border-0 m-0" id="btnSendChat" style="padding: 0.6rem 1rem;"><i class="bi bi-send"></i></button>
				</div>
			</div>
		</div>


		<!-- Bootstrap JS Bundle -->
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
		<script is:inline>
			document.addEventListener('DOMContentLoaded', () => {
				// Sidebar Toggle
				document.getElementById('sidebarToggle')?.addEventListener('click', () => {
					document.querySelector('.sidebar')?.classList.toggle('show');
				});

				// Alert from Redirects
				const urlParams = new URLSearchParams(window.location.search);
				if (urlParams.get('error') === 'forbidden') {
					Swal.fire({
						title: 'Acceso Denegado',
						text: 'No tienes los permisos necesarios para acceder a esa sección.',
						icon: 'warning',
						background: '#1e1f22',
						color: '#fff',
						confirmButtonColor: '#4f46e5',
						toast: true,
						position: 'top-end',
						timer: 3000,
						showConfirmButton: false
					});
					// Clean URL
					window.history.replaceState({}, document.title, window.location.pathname);
				}

				// Logout Handler
				document.getElementById('btnLogout')?.addEventListener('click', async () => {
					try {
						await fetch('/api/auth/logout', { method: 'POST' });
						window.location.href = '/login';
					} catch(e) {
						window.location.href = '/login';
					}
				});

				// Chat Logic
				const chatWidget = document.getElementById('chatWidget');
				const btnToggleChat = document.getElementById('btnToggleChat');
				const btnCloseChat = document.getElementById('btnCloseChat');
				const chatMessages = document.getElementById('chatMessages');
				const chatInput = document.getElementById('chatInput');
				const btnSendChat = document.getElementById('btnSendChat');
				const currentUserName = '{Astro.locals.user?.nombre_real || Astro.locals.user?.username || "Usuario"}';
				let chatInterval;

				const loadChat = async () => {
					try {
						const res = await fetch('/api/chat');
						const messages = await res.json();
						if(res.ok && Array.isArray(messages)) {
							chatMessages.innerHTML = '';
							messages.forEach(m => {
								const isMine = m.usuario === currentUserName;
								chatMessages.innerHTML += `
									<div class="message-bubble ${isMine ? 'mine' : ''}">
										<div class="message-user">${m.usuario}</div>
										<div>${m.mensaje}</div>
									</div>
								`;
							});
							chatMessages.scrollTop = chatMessages.scrollHeight;
						}
					} catch(e) { console.error("Error cargando chat", e); }
				};

				const sendMessage = async () => {
					const msg = chatInput.value.trim();
					if(!msg) return;
					chatInput.value = '';
					
					// Optimistic UI
					chatMessages.innerHTML += `
						<div class="message-bubble mine" style="opacity: 0.7;">
							<div class="message-user">${currentUserName}</div>
							<div>${msg}</div>
						</div>
					`;
					chatMessages.scrollTop = chatMessages.scrollHeight;

					try {
						await fetch('/api/chat', {
							method: 'POST',
							headers: {'Content-Type':'application/json'},
							body: JSON.stringify({ mensaje: msg })
						});
						loadChat();
					} catch(e) { console.error(e); }
				};

				btnToggleChat?.addEventListener('click', (e) => {
					e.preventDefault();
					chatWidget.classList.add('open');
					loadChat();
					chatInterval = setInterval(loadChat, 5000); // Poll every 5s
				});

				btnCloseChat?.addEventListener('click', () => {
					chatWidget.classList.remove('open');
					clearInterval(chatInterval);
				});

				btnSendChat?.addEventListener('click', sendMessage);
				chatInput?.addEventListener('keypress', (e) => {
					if(e.key === 'Enter') sendMessage();
				});
			});
		</script>
	</body>
</html>
