---
// Verifica si ya hay sesión para redirigir
if (Astro.locals.user) {
  return Astro.redirect('/');
}
---

<!doctype html>
<html lang="es" data-bs-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Iniciar Sesión | MiniSuper</title>
  
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <style>
    :root {
      --accent: 139, 92, 246;
      --accent-gradient: linear-gradient(135deg, rgb(var(--accent)), #4f46e5);
      --glass-bg: rgba(30, 31, 34, 0.7);
      --glass-border: rgba(255, 255, 255, 0.08);
    }
    
    body {
      font-family: 'Outfit', sans-serif;
      background-color: #0f1014;
      color: #e5e7eb;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background-image: 
        radial-gradient(circle at 15% 50%, rgba(var(--accent), 0.15), transparent 25%),
        radial-gradient(circle at 85% 30%, rgba(79, 70, 229, 0.15), transparent 25%);
      background-attachment: fixed;
    }

    .login-card {
      background: var(--glass-bg);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid var(--glass-border);
      border-radius: 20px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
      padding: 3rem;
      width: 100%;
      max-width: 450px;
    }

    .form-control {
      background-color: rgba(0, 0, 0, 0.2);
      border: 1px solid var(--glass-border);
      color: #fff;
      border-radius: 8px;
      padding: 0.75rem 1rem;
    }

    .form-control:focus {
      background-color: rgba(0, 0, 0, 0.4);
      border-color: rgb(var(--accent));
      color: #fff;
      box-shadow: 0 0 0 0.25rem rgba(var(--accent), 0.25);
    }

    .btn-primary-gradient {
      background: var(--accent-gradient);
      border: none;
      border-radius: 8px;
      padding: 0.8rem;
      font-weight: 600;
      box-shadow: 0 4px 15px rgba(var(--accent), 0.3);
      transition: all 0.3s ease;
      color: white;
    }
    
    .btn-primary-gradient:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(var(--accent), 0.4);
      color: white;
    }
  </style>
</head>
<body>

  <div class="login-card">
    <div class="text-center mb-4">
      <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 70px; height: 70px; background: var(--accent-gradient);">
        <i class="bi bi-shop text-white fs-1"></i>
      </div>
      <h1 class="h3 fw-bold text-white mb-1">Bienvenido</h1>
      <p class="text-muted small">Ingresa tus credenciales para continuar</p>
    </div>

    <form id="formLogin" class="needs-validation" novalidate>
      <div class="mb-4">
        <label class="form-label text-muted small text-uppercase fw-semibold">Correo / Usuario</label>
        <div class="input-group">
          <span class="input-group-text bg-transparent border-end-0 text-muted border-secondary"><i class="bi bi-person"></i></span>
          <input type="text" class="form-control border-start-0 ps-0 border-secondary" id="username" name="username" placeholder="admin@gmail.com" required autofocus>
        </div>
      </div>

      <div class="mb-5">
        <label class="form-label text-muted small text-uppercase fw-semibold">Contraseña</label>
        <div class="input-group">
          <span class="input-group-text bg-transparent border-end-0 text-muted border-secondary"><i class="bi bi-lock"></i></span>
          <input type="password" class="form-control border-start-0 ps-0 border-secondary" id="password" name="password" placeholder="••••••••" required>
        </div>
      </div>

      <button type="submit" class="btn btn-primary-gradient w-100 fs-5" id="btnSubmit">
        Ingresar al Sistema
      </button>
    </form>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const form = document.getElementById('formLogin');
      const btnSubmit = document.getElementById('btnSubmit');

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        if (!form.checkValidity()) {
          form.classList.add('was-validated');
          return;
        }

        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());

        const originalText = btnSubmit.innerHTML;

        try {
          btnSubmit.disabled = true;
          btnSubmit.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Autenticando...';

          const response = await fetch('/api/auth/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });

          let result;
          try {
            result = await response.json();
          } catch(e) {
            throw new Error('Error de conexión con el servidor.');
          }

          if (!response.ok || !result.success) {
            throw new Error(result.error || 'Credenciales inválidas');
          }

          // Éxito - recargar para que el middleware tome la nueva sesión y redirija
          window.location.href = '/';
          
        } catch (error) {
          if (window.Swal) {
            Swal.fire({
              title: 'Acceso Denegado',
              text: error.message,
              icon: 'error',
              background: '#1e1f22',
              color: '#fff',
              confirmButtonColor: '#4f46e5'
            });
          } else {
            alert('Acceso Denegado: ' + error.message);
          }
          btnSubmit.disabled = false;
          btnSubmit.innerHTML = originalText;
        }
      });
    });
  </script>

</body>
</html>
