---
import Layout from '../layouts/Layout.astro';

// Fetch a la API local que creamos (Astro SSR evalúa esto en el servidor)
const origin = Astro.url.origin;
const response = await fetch(`${origin}/api/productos`, {
	headers: { cookie: Astro.request.headers.get('cookie') || '' }
});
let productos = [];

if (response.ok) {
	productos = await response.json();
} else {
	console.error("Error al obtener productos", await response.text());
}

// Helper para fecha
const formatearFecha = (fechaStr: string) => {
	if (!fechaStr) return 'N/A';
	const fecha = new Date(fechaStr);
	// Ajustar la zona horaria si es necesario o usar UTC
	return fecha.toLocaleDateString('es-ES', { timeZone: 'UTC', year: 'numeric', month: 'short', day: 'numeric' });
};

// Lógica de Vencimiento
const evaluarVencimiento = (fechaStr: string) => {
	if (!fechaStr) return { estado: 'ok', mensaje: '' };
	const hoy = new Date();
	const venc = new Date(fechaStr);
	const diffTime = venc.getTime() - hoy.getTime();
	const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
	
	if (diffDays < 0) return { estado: 'expirado', mensaje: 'Expirado' };
	if (diffDays <= 7) return { estado: 'proximo', mensaje: `Vence en ${diffDays}d` };
	return { estado: 'ok', mensaje: '' };
};
---

<Layout title="Inventario de Productos">
	<div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3">
		<div>
			<h1 class="h3 fw-bold mb-1 text-white">Inventario General</h1>
			<p class="text-muted mb-0">Gestión y monitoreo de existencias</p>
		</div>
		<a href="/productos/nuevo" class="btn btn-primary-gradient">
			<i class="bi bi-plus-lg me-2"></i>Registrar Producto
		</a>
	</div>

	<div class="glass-card p-0 overflow-hidden">
		<div class="table-responsive">
			<table class="table table-hover align-middle mb-0">
				<thead style="background: rgba(0,0,0,0.2);">
					<tr>
						<th class="ps-4 py-3">Código</th>
						<th class="py-3">Producto</th>
						<th class="py-3">Categoría</th>
						<th class="py-3">P. Compra</th>
						<th class="py-3">P. Venta</th>
						<th class="py-3">Stock</th>
						<th class="py-3">Vencimiento</th>
						<th class="text-end pe-4 py-3">Acciones</th>
					</tr>
				</thead>
				<tbody>
					{productos.length === 0 ? (
						<tr>
							<td colspan="8" class="text-center py-5 text-muted">
								<i class="bi bi-inbox fs-1 d-block mb-2"></i>
								No hay productos registrados en el inventario.
							</td>
						</tr>
					) : (
						productos.map((prod: any) => {
							const vencimiento = evaluarVencimiento(prod.fecha_vencimiento);
							const stockBadgeClass = prod.alerta_stock 
								? 'badge-glow-danger' 
								: 'bg-secondary bg-opacity-25 text-white';
								
							return (
								<tr class={prod.alerta_stock ? 'row-alert-stock' : ''}>
									<td class="ps-4"><span class="text-muted font-monospace">{prod.codigo_barras || 'N/A'}</span></td>
									<td>
										<div class="fw-semibold text-white">{prod.nombre}</div>
									</td>
									<td><span class="badge bg-dark border border-secondary text-light">{prod.categoria_nombre || 'Sin Categoría'}</span></td>
									<td>${Number(prod.precio_compra).toFixed(2)}</td>
									<td>${Number(prod.precio_venta).toFixed(2)}</td>
									<td>
										<span class={`badge px-2 py-1 ${stockBadgeClass}`}>
											{prod.stock_actual} / {prod.stock_minimo || 0}
											{prod.alerta_stock && <i class="bi bi-exclamation-triangle-fill ms-1"></i>}
										</span>
									</td>
									<td>
										{prod.fecha_vencimiento ? (
											<div class="d-flex align-items-center gap-2">
												<span class="text-light">{formatearFecha(prod.fecha_vencimiento)}</span>
												{vencimiento.estado === 'expirado' && <span class="badge badge-glow-danger">{vencimiento.mensaje}</span>}
												{vencimiento.estado === 'proximo' && <span class="badge badge-glow-warning">{vencimiento.mensaje}</span>}
											</div>
										) : <span class="text-muted">N/A</span>}
									</td>
									<td class="text-end pe-4">
										<button class="btn btn-sm btn-outline-light border-0 me-1" title="Editar" onclick={`editarProducto(${prod.id_producto}, '${prod.nombre.replace(/'/g, "\\'")}', ${prod.precio_compra}, ${prod.precio_venta}, ${prod.stock_actual}, ${prod.stock_minimo || 0})`}><i class="bi bi-pencil"></i></button>
										<button class="btn btn-sm btn-outline-danger border-0" title="Eliminar" onclick={`eliminarProducto(${prod.id_producto})`}><i class="bi bi-trash"></i></button>
									</td>
								</tr>
							);
						})
					)}
				</tbody>
			</table>
		</div>
	</div>
</Layout>

<script is:inline>
	async function eliminarProducto(id) {
		const result = await Swal.fire({
			title: '¿Estás seguro?',
			text: "No podrás revertir esta acción",
			icon: 'warning',
			showCancelButton: true,
			background: '#1e1f22',
			color: '#fff',
			confirmButtonColor: '#ef4444',
			cancelButtonColor: '#4f46e5',
			confirmButtonText: 'Sí, eliminar',
			cancelButtonText: 'Cancelar'
		});

		if (result.isConfirmed) {
			try {
				const response = await fetch(`/api/productos/${id}`, { method: 'DELETE' });
				if (response.ok) {
					await Swal.fire({
						title: '¡Eliminado!',
						text: 'El producto ha sido eliminado del inventario.',
						icon: 'success',
						background: '#1e1f22',
						color: '#fff',
						confirmButtonColor: '#4f46e5',
						timer: 1500,
						showConfirmButton: false
					});
					window.location.reload();
				} else {
					throw new Error('Error al eliminar');
				}
			} catch (error) {
				Swal.fire({ title: 'Error', text: 'Ocurrió un error al eliminar el producto.', icon: 'error', background: '#1e1f22', color: '#fff' });
			}
		}
	}

	async function editarProducto(id, nombre, pCompra, pVenta, sActual, sMinimo) {
		const { value: formValues } = await Swal.fire({
			title: 'Editar Producto',
			html:
				`<div class="text-start mb-2"><label class="text-white small mb-1">Nombre</label><input id="swal-prod1" class="form-control" value="${nombre}"></div>` +
				`<div class="row"><div class="col-6 text-start mb-2"><label class="text-white small mb-1">P. Compra</label><input id="swal-prod2" type="number" step="0.01" class="form-control" value="${pCompra}"></div>` +
				`<div class="col-6 text-start mb-2"><label class="text-white small mb-1">P. Venta</label><input id="swal-prod3" type="number" step="0.01" class="form-control" value="${pVenta}"></div></div>` +
				`<div class="row"><div class="col-6 text-start mb-2"><label class="text-white small mb-1">Stock Actual</label><input id="swal-prod4" type="number" class="form-control" value="${sActual}"></div>` +
				`<div class="col-6 text-start mb-2"><label class="text-white small mb-1">Stock Mín.</label><input id="swal-prod5" type="number" class="form-control" value="${sMinimo}"></div></div>`,
			focusConfirm: false,
			showCancelButton: true,
			background: '#1e1f22',
			color: '#fff',
			confirmButtonColor: '#4f46e5',
			confirmButtonText: 'Guardar Cambios',
			width: '600px',
			preConfirm: () => {
				const n = document.getElementById('swal-prod1').value;
				if (!n) { Swal.showValidationMessage('El nombre es obligatorio'); return false; }
				return {
					nombre: n,
					precio_compra: parseFloat(document.getElementById('swal-prod2').value) || 0,
					precio_venta: parseFloat(document.getElementById('swal-prod3').value) || 0,
					stock_actual: parseInt(document.getElementById('swal-prod4').value) || 0,
					stock_minimo: parseInt(document.getElementById('swal-prod5').value) || 0
				};
			}
		});

		if (formValues) {
			try {
				const res = await fetch(`/api/productos/${id}`, {
					method: 'PUT',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify(formValues)
				});
				if (!res.ok) throw new Error('Error al actualizar');
				await Swal.fire({ title: 'Actualizado', text: 'Producto actualizado.', icon: 'success', background: '#1e1f22', color: '#fff', timer: 1500, showConfirmButton: false });
				window.location.reload();
			} catch (error) {
				Swal.fire({ title: 'Error', text: error.message, icon: 'error', background: '#1e1f22', color: '#fff' });
			}
		}
	}
</script>
