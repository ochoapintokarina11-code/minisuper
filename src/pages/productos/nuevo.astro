---
import Layout from '../../layouts/Layout.astro';

// Fetch de categorías para el select (SSR)
const origin = Astro.url.origin;
const response = await fetch(`${origin}/api/categorias`, {
	headers: { cookie: Astro.request.headers.get('cookie') || '' }
});
let categorias = [];

if (response.ok) {
	categorias = await response.json();
}
---

<Layout title="Nuevo Producto">
	<div class="mb-4">
		<a href="/" class="text-decoration-none text-muted mb-2 d-inline-block transition" style="transition: color 0.2s;">
			<i class="bi bi-arrow-left me-1"></i> Volver al inventario
		</a>
		<h1 class="h3 fw-bold mb-1 text-white">Registrar Nuevo Producto</h1>
		<p class="text-muted">Ingresa los datos del nuevo artículo para el inventario.</p>
	</div>

	<div class="row">
		<div class="col-lg-8">
			<div class="glass-card">
				<form id="formNuevoProducto" class="needs-validation" novalidate>
					
					<div class="row g-4 mb-4">
						<div class="col-md-6">
							<label class="form-label text-muted small text-uppercase fw-semibold">Código de Barras</label>
							<div class="input-group">
								<span class="input-group-text bg-transparent border-end-0 text-muted"><i class="bi bi-upc-scan"></i></span>
								<input type="text" class="form-control border-start-0 ps-0" id="codigo_barras" name="codigo_barras" required>
								<div class="invalid-feedback">Obligatorio.</div>
							</div>
						</div>
						
						<div class="col-md-6">
							<label class="form-label text-muted small text-uppercase fw-semibold">Nombre del Producto</label>
							<input type="text" class="form-control" id="nombre" name="nombre" placeholder="Ej: Arroz Diana 500g" required>
							<div class="invalid-feedback">Obligatorio.</div>
						</div>
					</div>

					<div class="row g-4 mb-4">
						<div class="col-md-4">
							<label class="form-label text-muted small text-uppercase fw-semibold">Precio Compra</label>
							<div class="input-group">
								<span class="input-group-text bg-transparent border-end-0 text-muted">$</span>
								<input type="number" step="0.01" min="0" class="form-control border-start-0 ps-0" id="precio_compra" name="precio_compra" required>
								<div class="invalid-feedback">Obligatorio.</div>
							</div>
						</div>
						
						<div class="col-md-4">
							<label class="form-label text-muted small text-uppercase fw-semibold">Precio Venta</label>
							<div class="input-group">
								<span class="input-group-text bg-transparent border-end-0 text-muted">$</span>
								<input type="number" step="0.01" min="0" class="form-control border-start-0 ps-0" id="precio_venta" name="precio_venta" required>
								<div class="invalid-feedback">Obligatorio.</div>
							</div>
						</div>

						<div class="col-md-4">
							<label class="form-label text-muted small text-uppercase fw-semibold">Categoría</label>
							<select class="form-select" id="id_categoria" name="id_categoria" required>
								<option value="" selected disabled>Seleccionar...</option>
								{categorias.map((cat: any) => (
									<option value={cat.id_categoria}>{cat.nombre}</option>
								))}
							</select>
							<div class="invalid-feedback">Selecciona una categoría.</div>
						</div>
					</div>

					<div class="row g-4 mb-5">
						<div class="col-md-4">
							<label class="form-label text-muted small text-uppercase fw-semibold">Stock Actual</label>
							<input type="number" min="0" class="form-control" id="stock_actual" name="stock_actual" required>
							<div class="invalid-feedback">Obligatorio.</div>
						</div>
						
						<div class="col-md-4">
							<label class="form-label text-muted small text-uppercase fw-semibold">Stock Mínimo</label>
							<input type="number" min="0" class="form-control" id="stock_minimo" name="stock_minimo" value="5">
						</div>

						<div class="col-md-4">
							<label class="form-label text-muted small text-uppercase fw-semibold">Vencimiento (Opcional)</label>
							<input type="date" class="form-control" id="fecha_vencimiento" name="fecha_vencimiento">
						</div>
					</div>

					<div class="d-flex justify-content-end gap-3 border-top pt-4" style="border-color: var(--glass-border) !important;">
						<button type="button" class="btn btn-outline-light" onclick="window.location.href='/'">Cancelar</button>
						<button type="submit" class="btn btn-primary-gradient" id="btnSubmit">
							<i class="bi bi-save me-2"></i>Guardar Producto
						</button>
					</div>
				</form>
			</div>
		</div>
		
		<div class="col-lg-4 d-none d-lg-block">
			<div class="glass-card h-100 d-flex flex-column justify-content-center align-items-center text-center p-4">
				<div class="rounded-circle d-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px; background: var(--accent-gradient);">
					<i class="bi bi-box-seam text-white fs-1"></i>
				</div>
				<h4 class="h5 fw-bold text-white mb-2">Información del Producto</h4>
				<p class="text-muted small">Al registrar un producto, asegúrate de ingresar correctamente el código de barras y establecer un stock mínimo prudente para recibir notificaciones a tiempo antes de que se agote la mercancía.</p>
			</div>
		</div>
	</div>
</Layout>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		const form = document.getElementById('formNuevoProducto');
		const btnSubmit = document.getElementById('btnSubmit');

		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			
			// Validación de Bootstrap
			if (!form.checkValidity()) {
				e.stopPropagation();
				form.classList.add('was-validated');
				return;
			}

			// Extraer datos
			const formData = new FormData(form);
			const data = {
				codigo_barras: formData.get('codigo_barras'),
				nombre: formData.get('nombre'),
				precio_compra: parseFloat(formData.get('precio_compra')),
				precio_venta: parseFloat(formData.get('precio_venta')),
				id_categoria: parseInt(formData.get('id_categoria')),
				stock_actual: parseInt(formData.get('stock_actual')),
				stock_minimo: parseInt(formData.get('stock_minimo')) || 0,
			};

			const fechaVencimiento = formData.get('fecha_vencimiento');
			if (fechaVencimiento) {
				data.fecha_vencimiento = fechaVencimiento;
			}

			const originalText = btnSubmit.innerHTML;

			try {
				btnSubmit.disabled = true;
				btnSubmit.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Guardando...';

				const response = await fetch('/api/productos', {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json'
					},
					body: JSON.stringify(data)
				});

				let result;
				try {
					result = await response.json();
				} catch (e) {
					throw new Error('La respuesta del servidor no es un JSON válido.');
				}

				if (!response.ok || !result.success) {
					throw new Error(result.error || 'Error al guardar el producto');
				}

				await Swal.fire({
					title: '¡Producto Registrado!',
					text: 'El artículo ha sido añadido al inventario con éxito.',
					icon: 'success',
					background: '#1e1f22',
					color: '#fff',
					confirmButtonColor: '#4f46e5'
				});
				window.location.href = '/';
				
			} catch (error) {
				Swal.fire({
					title: 'Atención',
					text: error.message,
					icon: 'error',
					background: '#1e1f22',
					color: '#fff',
					confirmButtonColor: '#4f46e5'
				});
			} finally {
				btnSubmit.disabled = false;
				btnSubmit.innerHTML = originalText;
			}
		});
	});
</script>
